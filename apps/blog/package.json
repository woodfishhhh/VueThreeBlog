{
  "name": "@woodfish-nest/blog",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "generate:content": "tsx ../../packages/content-tools/src/cli.ts generate && tsx ../../packages/content-tools/src/cli.ts optimize-images",
    "generate:content:ci": "tsx ../../packages/content-tools/src/cli.ts generate --reuse-assets",
    "optimize:images": "tsx ../../packages/content-tools/src/cli.ts optimize-images",
    "typecheck": "nuxt prepare && nuxt typecheck",
    "build": "nuxt generate",
    "build:with-content": "tsx ../../packages/content-tools/src/cli.ts generate && tsx ../../packages/content-tools/src/cli.ts optimize-images && nuxt generate",
    "build:deploy:dist": "cross-env NUXT_APP_BASE_URL=/newBlog/ nuxt generate && cross-env NUXT_APP_BASE_URL=/newBlog/ tsx ../../packages/content-tools/src/cli.ts verify-dist --base-path /newBlog/",
    "build:deploy": "tsx ../../packages/content-tools/src/cli.ts generate --reuse-assets && cross-env NUXT_APP_BASE_URL=/newBlog/ nuxt generate && cross-env NUXT_APP_BASE_URL=/newBlog/ tsx ../../packages/content-tools/src/cli.ts verify-dist --base-path /newBlog/",
    "verify:dist": "tsx ../../packages/content-tools/src/cli.ts verify-dist --dist-dir dist",
    "preview": "nuxt preview",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:e2e": "playwright test",
    "storybook": "storybook dev --port 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/matter-js": "^0.20.2",
    "gsap": "^3.14.2",
    "matter-js": "^0.20.0",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.2",
    "three": "^0.184.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@pinia/nuxt": "^0.11.3",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/blocks": "^8.6.18",
    "@storybook/vue3": "^10.4.0",
    "@storybook/vue3-vite": "^10.4.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.5.2",
    "@types/three": "^0.184.1",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/test-utils": "^2.4.6",
    "cross-env": "^10.1.0",
    "jsdom": "^29.0.1",
    "nuxt": "npm:nuxt-nightly@5x",
    "sharp": "^0.34.5",
    "storybook": "^10.4.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.2.6"
  }
}
