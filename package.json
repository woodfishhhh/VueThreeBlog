{
  "name": "vuecubeblog",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:content": "tsx scripts/generate-content.mts && tsx scripts/optimize-images.mts",
    "optimize:images": "tsx scripts/optimize-images.mts",
    "typecheck": "vue-tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "build:with-content": "npm run generate:content && npm run build",
    "preview": "vite preview",
    "analyze": "ANALYZE=true npm run build",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.10",
    "gray-matter": "^4.0.3",
    "isomorphic-dompurify": "^3.12.0",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.0.1",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "unified": "^11.0.5",
    "vite": "^8.0.10",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.8"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "github-slugger": "^2.0.0",
    "gsap": "^3.14.2",
    "highlight.js": "^11.11.1",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.2",
    "three": "^0.183.2",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  }
}
