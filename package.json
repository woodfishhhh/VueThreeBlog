{
  "name": "vuecubeblog",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:content": "tsx scripts/generate-content.mts && tsx scripts/optimize-images.mts",
    "generate:content:ci": "tsx scripts/generate-content.mts --reuse-assets",
    "optimize:images": "tsx scripts/optimize-images.mts",
    "typecheck": "vue-tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "build:with-content": "npm run generate:content && npm run build",
    "build:deploy": "npm run generate:content:ci && cross-env VITE_BASE_PATH=/newBlog/ npm run build && cross-env VITE_BASE_PATH=/newBlog/ npm run verify:dist",
    "verify:dist": "tsx scripts/verify-dist.mts",
    "deploy:vps": "powershell -ExecutionPolicy Bypass -File deploy/deploy.ps1",
    "preview": "vite preview",
    "analyze": "ANALYZE=true npm run build",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "cross-env": "^10.1.0",
    "gray-matter": "^4.0.3",
    "isomorphic-dompurify": "^3.9.0",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.0.1",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/matter-js": "^0.20.2",
    "github-slugger": "^2.0.0",
    "gsap": "^3.14.2",
    "highlight.js": "^11.11.1",
    "matter-js": "^0.20.0",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.2",
    "three": "^0.183.2",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  }
}
